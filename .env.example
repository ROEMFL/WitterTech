# Environment variables (names only — never commit real values).
# This is a static marketing site with no server secrets; the only variable
# is the GA4 Measurement ID, which is public/client-side.

# Optional. Overrides the GA4 id baked into lib/site.js (SITE.gaId).
# Set only in Vercel "Production" if you ever swap analytics properties.
# GA only loads on the production domain (VERCEL_ENV === 'production').
NEXT_PUBLIC_GA_ID=
